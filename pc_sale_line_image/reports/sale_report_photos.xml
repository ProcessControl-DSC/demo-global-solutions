<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_saleorder_photos" model="ir.actions.report">
        <field name="name">Quotation with photos</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pc_sale_line_image.report_saleorder_photos_document</field>
        <field name="report_file">pc_sale_line_image.report_saleorder_photos_document</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'%s - %s' % ((object.name or '').replace('/','_'), 'Fotos')</field>
    </record>

    <template id="report_saleorder_photos_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2 class="mt-4">
                            <span t-if="doc.state in ('draft','sent')">Presupuesto </span>
                            <span t-else="">Pedido </span>
                            <span t-field="doc.name"/>
                        </h2>
                        <div class="row mb-4">
                            <div class="col-6">
                                <strong>Cliente:</strong>
                                <div t-field="doc.partner_id"
                                     t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": true}'/>
                            </div>
                            <div class="col-6 text-end">
                                <div t-if="doc.date_order">
                                    <strong>Fecha:</strong> <span t-field="doc.date_order" t-options='{"widget": "date"}'/>
                                </div>
                                <div t-if="doc.validity_date">
                                    <strong>Validez:</strong> <span t-field="doc.validity_date"/>
                                </div>
                            </div>
                        </div>

                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th name="th_photo" style="width:15%;">Foto</th>
                                    <th name="th_desc">Descripción</th>
                                    <th name="th_qty" class="text-end">Cant.</th>
                                    <th name="th_uom" class="text-start">UdM</th>
                                    <th name="th_pu" class="text-end">Precio</th>
                                    <th name="th_sub" class="text-end">Importe</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.order_line" t-as="line">
                                    <tr t-if="line.display_type == 'line_section'" class="table-active">
                                        <td colspan="6"><strong t-field="line.name"/></td>
                                    </tr>
                                    <tr t-elif="line.display_type == 'line_note'">
                                        <td colspan="6"><em t-field="line.name"/></td>
                                    </tr>
                                    <tr t-elif="not line.display_type">
                                        <td class="text-center">
                                            <img t-if="line.line_image"
                                                 t-att-src="image_data_uri(line.line_image)"
                                                 style="max-height:70px; max-width:100%;"
                                                 alt="Foto"/>
                                        </td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-end"><span t-field="line.product_uom_qty"/></td>
                                        <td class="text-start"><span t-field="line.product_uom_id"/></td>
                                        <td class="text-end"><span t-field="line.price_unit"/></td>
                                        <td class="text-end">
                                            <span t-field="line.price_subtotal"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row justify-content-end mt-3">
                            <div class="col-5">
                                <table class="table table-sm">
                                    <tr>
                                        <td>Base imponible</td>
                                        <td class="text-end">
                                            <span t-field="doc.amount_untaxed"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Impuestos</td>
                                        <td class="text-end">
                                            <span t-field="doc.amount_tax"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr class="border-black o_total">
                                        <td><strong>Total</strong></td>
                                        <td class="text-end">
                                            <strong><span t-field="doc.amount_total"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div t-field="doc.note" class="mt-3"/>
                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
