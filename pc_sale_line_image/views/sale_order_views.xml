<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_line_image" model="ir.ui.view">
        <field name="name">sale.order.form.line.image</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="after">
                <field name="line_image" widget="image" class="oe_avatar"
                       optional="show" options="{'size': [45, 45]}"/>
            </xpath>
        </field>
    </record>
</odoo>
